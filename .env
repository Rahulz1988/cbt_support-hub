# ============================================================
# CBT Support Hub — Environment Configuration
# ============================================================
# NEVER commit this file to version control.
# .env is already listed in .gitignore.

# ── Environment ──────────────────────────────────────────────
# For LOCAL XAMPP development: keep as development
# For PRODUCTION SERVER: change to production
CI_ENVIRONMENT = production

# ── Application ───────────────────────────────────────────────
# Leave blank for auto-detection (works on both XAMPP and production)
# app.baseURL = 'http://localhost/cbt_support_hub/public/'

# ── Database ──────────────────────────────────────────────────
# XAMPP default credentials (change for production — use a dedicated user, NOT root)
database.default.hostname = 127.0.0.1
database.default.database = cbt_support_hub
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.port     = 3306

# ── Session ───────────────────────────────────────────────────
# savePath is set in Config/Session.php to WRITEPATH.'session' (outside web root)
# Do NOT set session.savePath here — it would override the safe path.

# ── Cookies ───────────────────────────────────────────────────
# Set cookie.secure = true only on production HTTPS servers
cookie.secure   = true
cookie.samesite = Lax

# ── Encryption ────────────────────────────────────────────────
# Used to encrypt/decrypt OTP values stored in the database.
# NEVER change this key after projects are created — existing OTPs will break.
# NEVER commit this key to version control.
encryption.key = hex2bin:9f4e2a1b8c7d5e3f6a9b2c4d7e8f1a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f

# ── Security ──────────────────────────────────────────────────
app.forceGlobalSecureRequests = true
session.timeToUpdate          = 300
session.secure         = true
session.httpOnly       = true
session.matchUserAgent = true
